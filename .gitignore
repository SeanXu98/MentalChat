# ============================================================
# MentalChat 项目 .gitignore 文件
# 确保敏感信息不会被上传到代码仓库
# ============================================================

# ==================== 敏感信息 ====================
# 环境变量文件（可能包含 API Key）
.env
.env.*
*.env
local.env

# API 密钥和凭证文件（但允许代码中使用这些变量名）
*api_key*.txt
*apikey*.txt
*secret*.txt
*credentials*.txt
*.pem
*.key

# ==================== 模型文件 ====================
# 大型模型权重文件（Git LFS 或单独存储）
# 注意：如果需要上传小模型，可以使用 Git LFS
*.bin
*.safetensors
*.gguf
*.pt
*.pth
*.ckpt
*.h5
*.onnx

# ==================== 文档和笔记 ====================
# 面试题文档（不应公开）
INTERVIEW.md
INTERVIEW_*.md

# 开发笔记和临时文档
NOTES.md
TODO.md
*.private.md
drafts/

# ==================== 日志文件 ====================
# 训练日志
logs/
runs/
wandb/
tensorboard/

# ==================== Python ====================
# 字节码
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
venv/
env/
.venv/
.env/
ENV/
env.bak/
venv.bak/

# 分发/打包
dist/
build/
*.egg-info/
*.egg
.eggs/
*.manifest
*.spec

# 单元测试 / 覆盖率
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ==================== IDE 和编辑器 ====================
# JetBrains IDEs (PyCharm, etc)
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# ==================== 操作系统 ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ==================== 临时文件 ====================
# 日志文件
*.log
*.log.*

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup
*~

# 压缩文件
*.zip
*.tar.gz
*.rar
*.7z

# ==================== 其他 ====================
# 大文件标记
*.large

# 本地配置覆盖
config.local.py
settings.local.py
